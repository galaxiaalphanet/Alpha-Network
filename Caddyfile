{
	auto_https off
}

alphanetx.xyz:80 {
	bind 0.0.0.0

	redir /whitepaper.html https://github.com/galaxiaalphanet/Alpha-Network/blob/main/whitepaper/ALPHA_WHITEPAPER.md 301

	handle /api/* {
		reverse_proxy localhost:8080 {
			header_down Cache-Control "no-cache, no-store, must-revalidate"
		}
	}
	handle /ws* {
		reverse_proxy localhost:8081
	}
	handle /health* {
		reverse_proxy localhost:8080
	}
	handle /faucet* {
		reverse_proxy localhost:8080
	}

	rewrite /presale /presale.html

	handle /explorer* {
		reverse_proxy localhost:8082 {
			header_down Cache-Control "no-cache, no-store, must-revalidate"
			header_down Pragma "no-cache"
			header_down Expires "0"
		}
	}
	handle {
		reverse_proxy localhost:3003 {
			header_down Cache-Control "no-cache, no-store, must-revalidate"
		}
	}
}
