{
  "name": "alpha-sdk",
  "version": "0.3.0",
  "description": "Alpha Network TypeScript/Node.js SDK — the blockchain built for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "peerDependencies": {
    "ws": ">=8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10"
  },
  "keywords": [
    "alpha-network",
    "blockchain",
    "ai-agents",
    "sdk",
    "typescript",
    "crypto",
    "proof-of-intelligence"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alpha-network/alpha"
  }
}
